# APS Web Tools — Environment Variables
# Copy to .env.local and fill in your values.
# ⚠️  NEVER commit .env.local. It's in .gitignore.

# From: https://aps.autodesk.com/myapps → your app
VITE_APS_CLIENT_ID=your_client_id_here
APS_CLIENT_SECRET=your_client_secret_here     # ← NO VITE_ prefix! NEVER reaches browser.
VITE_APS_CALLBACK_URL=http://localhost:3000/auth/callback

# Optional: pre-select hub/project (skips hub browser)
# VITE_APS_HUB_ID=b.your-hub-id
# VITE_APS_PROJECT_ID=b.your-project-id
